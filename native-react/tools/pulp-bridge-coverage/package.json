{
  "name": "pulp-bridge-coverage",
  "version": "0.1.0",
  "description": "AOT analyzer that reports W3C-spec coverage (Canvas 2D / DOM / SVG / form controls) of a JS bundle against the Pulp WidgetBridge surface. Sibling of pulp-css-analyze.",
  "type": "module",
  "bin": {
    "pulp-bridge-coverage": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.25.6",
    "@babel/traverse": "^7.25.6",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^20.16.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
